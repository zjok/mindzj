{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "MindZJ",
    "version": "0.1.0",
    "identifier": "com.mindzj.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1430",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "MindZJ",
                "width": 1280,
                "height": 800,
                "minWidth": 100,
                "minHeight": 100,
                "resizable": true,
                "fullscreen": false,
                "decorations": false,
                "transparent": false,
                "visible": false
            }
        ],
        "security": {
            "assetProtocol": {
                "enable": true,
                "scope": {
                    "allow": ["**", "**/.mindzj/**"],
                    "requireLiteralLeadingDot": false
                }
            },
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": ["resources/default_plugins/"],
        "icon": [
            "icons/icon.ico",
            "icons/1024x1024.png",
            "icons/512x512.png",
            "icons/256x256.png",
            "icons/128x128.png",
            "icons/64x64.png",
            "icons/48x48.png",
            "icons/32x32.png",
            "icons/16x16.png"
        ]
    },
    "plugins": {
        "fs": {
            "requireLiteralLeadingDot": false
        }
    }
}
