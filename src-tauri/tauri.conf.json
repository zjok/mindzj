{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "MindZJ",
    "version": "0.1.1",
    "identifier": "com.mindzj.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1430",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "MindZJ",
                "width": 1080,
                "height": 720,
                "minWidth": 480,
                "minHeight": 320,
                "resizable": true,
                "fullscreen": false,
                "decorations": false,
                "transparent": false,
                "visible": false,
                "backgroundColor": "#1e1e1e"
            }
        ],
        "security": {
            "assetProtocol": {
                "enable": true,
                "scope": {
                    "allow": ["**", "**/.mindzj/**"],
                    "requireLiteralLeadingDot": false
                }
            },
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["msi", "nsis", "deb", "appimage", "rpm", "app", "dmg"],
        "publisher": "SuperJohn",
        "copyright": "Copyright (c) 2026 SuperJohn. Licensed under AGPL-3.0-or-later.",
        "category": "Productivity",
        "shortDescription": "AI-native, CLI-first, local note-taking",
        "longDescription": "MindZJ is an AI-native, CLI-first, open-source local note-taking system built on Tauri 2 + SolidJS + CodeMirror 6. Licensed under AGPL-3.0-or-later with an optional commercial license.",
        "licenseFile": "../LICENSE",
        "resources": ["resources/default_plugins/"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "installerIcon": "icons/icon.ico"
            }
        }
    },
    "plugins": {
        "fs": {
            "requireLiteralLeadingDot": false
        }
    }
}
